  <property name="styleSheet">
   <string notr="true">/* 1. Sidebar Background - Light Beige */
QFrame#sidebarFrame {
    background-color: #FDFBF7; /* Soft, warm beige-white */
    border-right: 1px solid #e2e8f0;
}

/* 2. Navigation Buttons Styling */
QPushButton#btnOverview, QPushButton#btnManagerStaff, QPushButton#btnScheduling {
    background-color: transparent;
    border-radius: 8px;
    padding: 10px 15px;
    color: #475569;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-weight: 600;
    text-align: left;
    margin: 5px 10px;
}

/* Hover effect */
QPushButton#btnOverview:hover, QPushButton#btnManagerStaff:hover, QPushButton#btnScheduling:hover {
    background-color: #f1ede6; /* Slightly darker beige on hover */
    color: #1e293b;
}

/* Active state for selected tab */
QPushButton#btnOverview:checked, QPushButton#btnManagerStaff:checked, QPushButton#btnScheduling:checked {
    background-color: #e5e0d7; 
    color: #3f352a;
    border-left: 4px solid #3f352a;
}</string>
